<div class="dashboard-container">

    <h2 class="title">Customer Dashboard</h2>

    <div class="grid">

        <!-- Create Request -->
        <div class="card">
            <h3>Create Request</h3>

            <input id="title" placeholder="Title" required />
            <input type="text" id="description" placeholder="Description" />
            <input id="lat" type="number" step="any" placeholder="Latitude" />
            <input id="lng" type="number" step="any" placeholder="Longitude" />

            <button onclick="createRequest()">Create</button>
        </div>

        <!-- Requests -->
        <div class="card">
            <h3>My Requests</h3>

            <button onclick="loadMyRequests()">Load Requests</button>

            <ul id="requestsList" class="requests"></ul>
        </div>

    </div>

</div>

<link rel="stylesheet" href="/css/site.css" />
<script src="/js/app.js"></script>